# Backend origin (Swagger: api-docs on same origin)
VITE_API_URL=http://localhost:5000

# Optional: enable "Continue with Google" on Login / Sign up (OAuth web client ID from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# Optional fallback IDs for web (comma-separated); used if primary ID fails popup/origin checks
VITE_GOOGLE_CLIENT_IDS=

# Optional: LocationIQ key for onboarding location screens (search, reverse geocode, static map)
VITE_LOCATIONIQ_API_KEY=

# Optional: Mapbox public token for onboarding "Where are you based?" (interactive map, search, current location)
VITE_MAPBOX_ACCESS_TOKEN=
